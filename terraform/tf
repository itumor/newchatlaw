#!/usr/bin/env sh
set -eu

script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
repo_root=$(CDPATH= cd -- "$script_dir/.." && pwd)
env_file="$repo_root/.env"

if [ ! -f "$env_file" ]; then
  echo "Missing root .env file: $env_file" >&2
  exit 1
fi

env_value() {
  key="$1"
  awk -F= -v key="$key" '
    $0 ~ "^[[:space:]]*" key "=" {
      sub("^[^=]*=", "")
      gsub(/^[[:space:]]+|[[:space:]]+$/, "")
      print
      exit
    }
  ' "$env_file"
}

BEDROCK_AWS_ACCESS_KEY_ID=$(env_value BEDROCK_AWS_ACCESS_KEY_ID)
BEDROCK_AWS_SECRET_ACCESS_KEY=$(env_value BEDROCK_AWS_SECRET_ACCESS_KEY)
BEDROCK_AWS_DEFAULT_REGION=$(env_value BEDROCK_AWS_DEFAULT_REGION)

if [ -z "${BEDROCK_AWS_ACCESS_KEY_ID:-}" ]; then
  echo "BEDROCK_AWS_ACCESS_KEY_ID is missing from $env_file" >&2
  exit 1
fi

if [ -z "${BEDROCK_AWS_SECRET_ACCESS_KEY:-}" ]; then
  echo "BEDROCK_AWS_SECRET_ACCESS_KEY is missing from $env_file" >&2
  exit 1
fi

if [ -z "${BEDROCK_AWS_DEFAULT_REGION:-}" ]; then
  echo "BEDROCK_AWS_DEFAULT_REGION is missing from $env_file" >&2
  exit 1
fi

export AWS_ACCESS_KEY_ID="$BEDROCK_AWS_ACCESS_KEY_ID"
export AWS_SECRET_ACCESS_KEY="$BEDROCK_AWS_SECRET_ACCESS_KEY"
export AWS_DEFAULT_REGION="$BEDROCK_AWS_DEFAULT_REGION"
export TF_VAR_region="${TF_VAR_region:-$BEDROCK_AWS_DEFAULT_REGION}"

cd "$script_dir"
exec terraform "$@"
