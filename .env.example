COMPOSE_PROJECT_NAME=newchatlaw

UID=1000
GID=1000

HOST=0.0.0.0
PORT=3080
DOMAIN_CLIENT=http://localhost
DOMAIN_SERVER=http://localhost

MONGO_URI=mongodb://mongodb:27017/LibreChat
NO_INDEX=true
DEBUG_LOGGING=true
DEBUG_CONSOLE=false
ALLOW_REGISTRATION=true
ALLOW_EMAIL_LOGIN=true

OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
GOOGLE_KEY=your_google_api_key
LIBRECHAT_AGENT_API_KEY=replace_with_librechat_agent_api_key
LIBRECHAT_AGENT_BASE_URL=http://localhost
LIBRECHAT_AGENT_MODEL_HAIKU=agent_FCpGDtKOPOczIlqGUPm_p
LIBRECHAT_AGENT_RECURSION_LIMIT=60

CONFIG_PATH=/app/librechat.yaml

CREDS_KEY=replace_with_64_char_hex_key
CREDS_IV=replace_with_32_char_hex_iv
JWT_SECRET=replace_with_secure_random_secret
JWT_REFRESH_SECRET=replace_with_secure_random_refresh_secret
MEILI_MASTER_KEY=replace_with_meilisearch_master_key

RAG_PORT=8000

POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace_with_postgres_password
POSTGRES_RO_USER=librechat_ro
POSTGRES_RO_PASSWORD=replace_with_readonly_password
DATABASE_URL=postgresql://username:password@hostname:5432/database_name?sslmode=require
BI_BASE_URL=http://localhost:38081

PGMCP_HTTP_ADDR=:8080
PGMCP_HTTP_PATH=/mcp

#=================#
#   AWS Bedrock   #
#=================#

BEDROCK_AWS_DEFAULT_REGION=us-west-2
BEDROCK_AWS_ACCESS_KEY_ID=your_bedrock_access_key_id
BEDROCK_AWS_SECRET_ACCESS_KEY=your_bedrock_secret_access_key
# BEDROCK_AWS_SESSION_TOKEN=your_bedrock_session_token

# Note: This example list is not meant to be exhaustive. If omitted, all known, supported model IDs will be included for you.
# BEDROCK_AWS_MODELS=anthropic.claude-sonnet-4-6,anthropic.claude-opus-4-6-v1,anthropic.claude-3-5-sonnet-20240620-v1:0,meta.llama3-1-8b-instruct-v1:0
# Cross-region inference model IDs: us.anthropic.claude-sonnet-4-6,us.anthropic.claude-opus-4-6-v1,global.anthropic.claude-opus-4-6-v1

# See all Bedrock model IDs here: https://docs.aws.amazon.com/bedrock/latest/userguide/model-ids.html#model-ids-arns

# Notes on specific models:
# The following models are not support due to not supporting streaming:
# ai21.j2-mid-v1

# The following models are not support due to not supporting conversation history:
# ai21.j2-ultra-v1, cohere.command-text-v14, cohere.command-light-text-v14
